<?xml version="1.0" encoding="UTF-8"?>
<OpenSCENARIO>
  <FileHeader description="ALKS 4.2d - Pedestrian crossing at 5 km/h" author="ALKS_Test" revMajor="1" revMinor="0" date="2025-01-01T00:00:00"/>
  <ParameterDeclarations/>
  <CatalogLocations/>
  <RoadNetwork>
    <LogicFile filepath="D:\files\alks_highway.xodr"/>
  </RoadNetwork>
  <Entities>
  <ScenarioObject name="Ego">
      <Vehicle name="vehicle.tesla.model3" vehicleCategory="car">
        <BoundingBox><Center x="1.5" y="0.0" z="0.9"/><Dimensions width="2.1" length="4.69" height="1.81"/></BoundingBox>
        <Performance maxSpeed="69.44" maxAcceleration="10.0" maxDeceleration="10.0"/>
        <Axles>
          <FrontAxle maxSteering="0.5236" wheelDiameter="0.623" trackWidth="1.8" positionX="3.1" positionZ="0.312"/>
          <RearAxle  maxSteering="0.0"    wheelDiameter="0.623" trackWidth="1.8" positionX="0.0" positionZ="0.312"/>
        </Axles>
        <Properties>
          <Property name="type" value="ego_vehicle"/>
          <Property name="role_name" value="hero"/>
        </Properties>
      </Vehicle>
    </ScenarioObject>
  <ScenarioObject name="CrPed">
      <Pedestrian name="walker.pedestrian.0002" pedestrianCategory="pedestrian">
        <BoundingBox><Center x="0.0" y="0.0" z="0.9"/><Dimensions width="0.6" length="0.6" height="1.8"/></BoundingBox>
        <Properties><Property name="type" value="simulation"/></Properties>
      </Pedestrian>
    </ScenarioObject>
  </Entities>
  <Storyboard>
    <Init><Actions>
      <Private entityRef="Ego">
        <PrivateAction><TeleportAction><Position>
          <LanePosition roadId="1" laneId="-2" s="50" offset="0.0"/>
        </Position></TeleportAction></PrivateAction>
        <PrivateAction><LongitudinalAction><SpeedAction>
          <SpeedActionDynamics dynamicsShape="step" value="0.0" dynamicsDimension="time"/>
          <SpeedActionTarget><AbsoluteTargetSpeed value="27.78"/></SpeedActionTarget>
        </SpeedAction></LongitudinalAction></PrivateAction>
      </Private>
      <Private entityRef="CrPed">
        <PrivateAction><TeleportAction><Position>
          <LanePosition roadId="1" laneId="-3" s="310" offset="1.5"/>
        </Position></TeleportAction></PrivateAction>
        <PrivateAction><LongitudinalAction><SpeedAction>
          <SpeedActionDynamics dynamicsShape="step" value="0.0" dynamicsDimension="time"/>
          <SpeedActionTarget><AbsoluteTargetSpeed value="0.0"/></SpeedActionTarget>
        </SpeedAction></LongitudinalAction></PrivateAction>
      </Private>
    </Actions></Init>
    <Story name="S42d">
      <Act name="Act">
        <ManeuverGroup name="MG" maximumExecutionCount="1">
          <Actors selectTriggeringEntities="false"><EntityRef entityRef="CrPed"/></Actors>
          <Maneuver name="M">
            <Event name="Ev_Walk" priority="overwrite">
              <Action name="A_Walk">
                <PrivateAction><LongitudinalAction><SpeedAction>
                  <SpeedActionDynamics dynamicsShape="step" value="0.0" dynamicsDimension="time"/>
                  <SpeedActionTarget><AbsoluteTargetSpeed value="1.39"/></SpeedActionTarget>
                </SpeedAction></LongitudinalAction></PrivateAction>
              </Action>
              <StartTrigger><ConditionGroup><Condition name="C_dist" delay="0.0" conditionEdge="rising">
                <ByEntityCondition>
                  <TriggeringEntities triggeringEntitiesRule="any"><EntityRef entityRef="Ego"/></TriggeringEntities>
                  <EntityCondition><ReachPositionCondition tolerance="120.0">
                    <Position><LanePosition roadId="1" laneId="-2" s="310" offset="0.0"/></Position>
                  </ReachPositionCondition></EntityCondition>
                </ByEntityCondition>
              </Condition></ConditionGroup></StartTrigger>
            </Event>
          </Maneuver>
        </ManeuverGroup>
        <StartTrigger><ConditionGroup><Condition name="CS" delay="0.0" conditionEdge="none">
          <ByValueCondition><SimulationTimeCondition value="0.0" rule="greaterThan"/></ByValueCondition>
        </Condition></ConditionGroup></StartTrigger>
        <StopTrigger><ConditionGroup><Condition name="CE" delay="0.0" conditionEdge="none">
          <ByValueCondition><SimulationTimeCondition value="50.0" rule="greaterThan"/></ByValueCondition>
        </Condition></ConditionGroup></StopTrigger>
      </Act>
    </Story>
    <StopTrigger><ConditionGroup><Condition name="CG" delay="0.0" conditionEdge="none">
      <ByValueCondition><SimulationTimeCondition value="50.0" rule="greaterThan"/></ByValueCondition>
    </Condition></ConditionGroup></StopTrigger>
  </Storyboard>
</OpenSCENARIO>
